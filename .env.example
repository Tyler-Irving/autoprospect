# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://autoprospect:autoprospect@localhost:5433/autoprospect

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-api-key

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Mapbox (frontend uses VITE_ prefix)
VITE_MAPBOX_TOKEN=your-mapbox-token
VITE_API_URL=http://localhost:8000/api

# Email — Resend
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=AutoProspect <you@yourdomain.com>
EMAIL_REPLY_TO=you@gmail.com

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
VITE_GITHUB_CLIENT_ID=your-github-client-id

# Budget Controls
MONTHLY_API_BUDGET_CENTS=30000
MAX_BUSINESSES_PER_SCAN=300
